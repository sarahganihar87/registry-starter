# AURA Design System Registry — Environment
#
# Automatically populated when deployed on Vercel
# https://vercel.com/docs/environment-variables/system-environment-variables
VERCEL_PROJECT_PRODUCTION_URL=registry-starter.vercel.app

# Optional: Enable MCP (Model Context Protocol) integration
# Set to "enabled" to allow AI tools (Claude, Cursor, etc.) to read your
# design system tokens and components programmatically via the registry API
# REGISTRY_MCP_ENABLED=enabled

# Optional: Protect the registry with an auth token for MCP access
# Generate with: openssl rand -hex 32
# REGISTRY_AUTH_TOKEN=

# Optional: Your AURA Firebase project ID for deployment
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
